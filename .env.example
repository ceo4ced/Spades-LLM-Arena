# API keys for the LLM connectors. Copy this file to .env.local and fill in the
# providers you actually use — leave the rest blank.
#
# SECURITY NOTE: Vite bakes these into the JS bundle at build time. They are
# present in any built site you ship. Treat the keys here like development
# credentials, not production secrets. For production deployment, proxy
# provider calls through your own backend instead of exposing the keys to the
# browser.

# Google Gemini — for direct Gemini Flash / Gemini Pro agents.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# Anthropic — for direct Claude Opus / Sonnet / Haiku agents.
ANTHROPIC_API_KEY="MY_ANTHROPIC_API_KEY"

# OpenAI — for direct GPT-4o / GPT-4o Mini agents.
OPENAI_API_KEY="MY_OPENAI_API_KEY"

# OpenRouter — gateway agent for many third-party models.
OPENROUTER_API_KEY="MY_OPENROUTER_API_KEY"

# YouTube — used by `npm run stream:live` to broadcast bot-vs-bot matches.
# Read server-side by stream/orchestrator.ts; not exposed to the browser.
YOUTUBE_STREAM_KEY="MY_YOUTUBE_STREAM_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
APP_URL="MY_APP_URL"
